# Server Configuration
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Agent Authentication
# JSON object mapping agentId to secret key
AGENT_KEYS_JSON={"home-pc-1":"your-secret-key-here","home-pc-2":"another-secret-key"}

# Optional: Internal Bearer Token for /sse endpoints
# If set, requires Authorization: Bearer <token> for MCP requests
# INTERNAL_BEARER_TOKEN=your-bearer-token-here

# Gateway Configuration
AGENT_AUTO_NAMESPACE=true
DISABLE_AUTO_PREFIX=false
ALLOW_SINGLE_AGENT_FALLBACK=true
AGENT_CAPABILITY_CACHE_TTL_MS=60000
AGENT_CALL_TIMEOUT_MS=30000
AGENT_KEEPALIVE_INTERVAL_MS=15000

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AGENT_WS_MAX=10

# Duplicate Agent Connection Strategy
# Options: "kick_old" (disconnect existing), "reject_new" (keep existing)
DUPLICATE_AGENT_STRATEGY=kick_old

# Metrics
ENABLE_METRICS=true

# SSE Configuration
SSE_KEEPALIVE_INTERVAL_MS=15000
SSE_KEEPALIVE_COMMENT=:keepalive

# Agent HTTP Polling (Mode 2 - Optional)
# JSON object mapping agentId to HTTP base URL
# AGENT_HTTP_URLS_JSON={"agent-1":"http://localhost:4001","agent-2":"http://localhost:4002"}
# AGENT_HTTP_POLL_INTERVAL_MS=30000

# -------- A2A Protocol --------
PUBLIC_URL=https://gateway.your-domain.com
A2A_ENABLED=true

# -------- Observability --------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
